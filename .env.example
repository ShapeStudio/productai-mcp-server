# --- Server ---
PORT=8080
PUBLIC_URL=https://mcp.productai.photo

# --- ProductAI / Relum API upstream ---
# Production: https://relum-api-production-cef0fcef8ef6.herokuapp.com/v1
PRODUCTAI_API_BASE=https://api.productai.photo/v1

# --- Postgres (same RDS as relum-api, or a separate DB) ---
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Auth0 (productai tenant) ---
AUTH0_DOMAIN=productai.eu.auth0.com
AUTH0_ISSUER_BASE_URL=https://productai.eu.auth0.com/
# Audience must match relum-api's AUTH0_AUDIENCE so the Auth0 token works against /api endpoints
AUTH0_AUDIENCE=https://relum-api-production-cef0fcef8ef6.herokuapp.com/v1

# Create a *new* "Regular Web Application" in Auth0 for the MCP server
# (separate from the relum-api client). Allowed Callback URL must include:
#   ${PUBLIC_URL}/oauth/callback
AUTH0_MCP_CLIENT_ID=
AUTH0_MCP_CLIENT_SECRET=

# --- MCP-issued tokens ---
# Used to sign the access/refresh tokens we hand to Claude. openssl rand -base64 64
OAUTH_JWT_SECRET=replace-with-long-random-string
OAUTH_ACCESS_TOKEN_TTL=3600
OAUTH_REFRESH_TOKEN_TTL=2592000

# --- Observability (optional) ---
# Sentry DSN — leave blank to disable error reporting.
SENTRY_DSN=
LOG_LEVEL=info
